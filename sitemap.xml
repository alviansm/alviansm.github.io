---
layout: null
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <!-- Homepage -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  
  <!-- Category Pages (as sub-pages of homepage) -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/devlog/</loc>
    <lastmod>{% if site.categories.Devlog.size > 0 %}{% for post in site.categories.Devlog limit:1 %}{{ post.date | date_to_xmlschema }}{% endfor %}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/notes/</loc>
    <lastmod>{% if site.categories.Notes.size > 0 %}{% for post in site.categories.Notes limit:1 %}{{ post.date | date_to_xmlschema }}{% endfor %}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/essay/</loc>
    <lastmod>{% if site.categories.Essay.size > 0 %}{% for post in site.categories.Essay limit:1 %}{{ post.date | date_to_xmlschema }}{% endfor %}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/project/</loc>
    <lastmod>{% if site.categories.Project.size > 0 %}{% for post in site.categories.Project limit:1 %}{{ post.date | date_to_xmlschema }}{% endfor %}{% else %}{{ site.time | date_to_xmlschema }}{% endif %}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- Individual Posts (organized by category) -->
  {% for post in site.categories.Devlog %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}

  {% for post in site.categories.Notes %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}

  {% for post in site.categories.Essay %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}

  {% for post in site.categories.Project %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}

  <!-- Other Posts (not in main categories) -->
  {% for post in site.posts %}
    {% unless post.categories contains 'Devlog' or post.categories contains 'Notes' or post.categories contains 'Essay' or post.categories contains 'Project' %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ post.url }}</loc>
    <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
    {% endunless %}
  {% endfor %}

  <!-- About Page -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/about/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>

  <!-- Tags and Archive Pages -->
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/tags.html</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>
  
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}/archive.html</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>

  <!-- Other Static Pages (excluding duplicates and unwanted pages) -->
  {% for page in site.pages %}
    {% unless page.url contains '/404' or 
             page.url contains '/feed' or 
             page.url contains '/sitemap' or 
             page.url contains '.css' or
             page.url == '/devlog/' or
             page.url == '/notes/' or
             page.url == '/essay/' or
             page.url == '/project/' or
             page.url == '/about/' or
             page.url == '/about' or
             page.url == '/tags.html' or
             page.url == '/tags.html/' or
             page.url == '/archive.html' or
             page.url == '/archive.html/' or
             page.url == '/' %}
  <url>
    <loc>{{ site.url }}{{ site.baseurl }}{{ page.url }}</loc>
    {% if page.date %}
    <lastmod>{{ page.date | date_to_xmlschema }}</lastmod>
    {% else %}
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    {% endif %}
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
    {% endunless %}
  {% endfor %}
</urlset>